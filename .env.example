# Copy this file to .env and adjust values for your machine.
# .env is gitignored — never commit it.
#
# ROS_DOMAIN_ID: integer 0-101. All ROS2 nodes on the same domain can see each other.
# Change if other ROS2 systems share your network and you need to isolate traffic.
# Default 0 is correct for a dedicated network.
ROS_DOMAIN_ID=0
